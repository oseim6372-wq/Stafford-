];

function tagHtml(status){
  const map={
    'in-stock':['in-stock','● In Stock'],
    'limited': ['limited','◐ Limited'],
    'out':     ['out','○ Out of Stock']
  };
  const [cls,label]=map[status]||map['in-stock'];
  return `<span class="avail-tag ${cls}">${label}</span>`;
}

function renderProducts(products){
  const grid=document.getElementById('productGrid');
  grid.innerHTML=products.map(p=>`
    <div class="p-card">
      <div class="p-icon">
        ${[0,1,2,3,4,5].map(i=>`<div class="pi" style="background:${i%2===0?p.c1:p.c2}"></div>`).join('')}
      </div>
      <div class="p-name">${p.name}</div>
      <p class="p-desc">${p.desc}</p>
      <div class="p-specs">${p.specs.map(s=>`<span class="spec">${s}</span>`).join('')}</div>
      ${tagHtml(p.status)}
    </div>
  `).join('');
}

// Real-time listener
const prodRef = ref(db, 'products');
onValue(prodRef, snap => {
  const data = snap.val();
  if(data){
    const arr = Object.values(data);
    renderProducts(arr.length ? arr : DEFAULT_PRODUCTS);
  } else {
    // Seed defaults
    DEFAULT_PRODUCTS.forEach(p => set(ref(db,`products/${p.id}`), p));
    renderProducts(DEFAULT_PRODUCTS);
  }
});

