      {elementType:'labels.text.fill',stylers:[{color:'#4a4540'}]},
      {elementType:'labels.text.stroke',stylers:[{color:'#fdfcfb'}]},
      {featureType:'road',elementType:'geometry',stylers:[{color:'#e8e2da'}]},
      {featureType:'road.highway',elementType:'geometry',stylers:[{color:'#d4c8bc'}]},
      {featureType:'water',elementType:'geometry',stylers:[{color:'#c8d8e8'}]},
      {featureType:'poi',stylers:[{visibility:'off'}]},
      {featureType:'transit',stylers:[{visibility:'off'}]}
