  new google.maps.Circle({map,center:factory,radius:150000,fillColor:'#e8a020',fillOpacity:.06,strokeColor:'#e8a020',strokeWeight:1.5,strokeOpacity:.4,strokeDashArray:'5,5'});
  new google.maps.Marker({map,position:factory,icon:{path:google.maps.SymbolPath.CIRCLE,scale:8,fillColor:'#d9450c',fillOpacity:1,strokeColor:'#fff',strokeWeight:2},title:'Stafford Factory'});
  // Try geolocation
  locateMe();
};

window.locateMe = function(){
  if(!navigator.geolocation){showToast('Geolocation not supported');return}
  navigator.geolocation.getCurrentPosition(pos=>{
    if(!map) return;
    const loc = {lat:pos.coords.latitude,lng:pos.coords.longitude};
    if(userMarker) userMarker.setMap(null);
    userMarker = new google.maps.Marker({map,position:loc,title:'Your Location',icon:{path:google.maps.SymbolPath.CIRCLE,scale:10,fillColor:'#d9450c',fillOpacity:.9,strokeColor:'#fff',strokeWeight:2.5}});
    map.setCenter(loc);
    map.setZoom(11);
    // Reverse geocode to check zone
    const gc = new google.maps.Geocoder();
    gc.geocode({location:loc},results=>{
      if(results&&results[0]){
        const town=(results[0].address_components.find(c=>c.types.includes('locality'))||{}).long_name||'';
        if(town){
          document.getElementById('checkInput').value=town;
          doCheck();
        }
      }
    });
  },()=>showToast('Could not get your location'));
};
